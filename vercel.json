{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "vite.config.ts",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_HERO_VIDEO_URL": "@vite_hero_video_url",
    "VITE_CROWD_VIDEO_URL": "@vite_crowd_video_url",
    "VITE_RETAIL_VIDEO_URL": "@vite_retail_video_url",
    "VITE_DINING_VIDEO_URL": "@vite_dining_video_url",
    "VITE_ATTRACTION_VIDEO_URL": "@vite_attraction_video_url"
  }
}
